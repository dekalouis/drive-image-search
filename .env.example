# Database (PostgreSQL with pgvector support required)
DATABASE_URL="postgresql://username:password@localhost:5432/drive_searcher?schema=public"

# Redis for BullMQ job queues
REDIS_URL="redis://localhost:6379"

# Google APIs
GOOGLE_DRIVE_API_KEY="your_google_drive_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"

# Development (optional - for email confirmation redirects)
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL="http://localhost:3000"

# Image Limits
MAX_IMAGES_PER_FOLDER=200
NEXT_PUBLIC_MAX_IMAGES_PER_FOLDER=200

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Token Encryption (generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=your_32_byte_hex_key_here

# Rate limit (requests per minute) - Tier 1 default is 1000
GEMINI_RATE_LIMIT=1000

# Image worker concurrency - lower = smoother, higher = faster
IMAGE_WORKER_CONCURRENCY=2

# Admin secret for /api/health and /api/processing-stats (generate with: openssl rand -hex 32)
ADMIN_SECRET_TOKEN=your_admin_secret_token_here

# OAuth token TTL in minutes (ARCH-007). Google tokens expire in 60min; default 55min is conservative.
# Clerk does not expose the actual expires_in so this is a best-effort setting.
OAUTH_TOKEN_TTL_MINUTES=55

# Database connection pooling — add these params to DATABASE_URL for Railway
# DATABASE_URL="postgresql://...?connection_limit=5&pool_timeout=10"